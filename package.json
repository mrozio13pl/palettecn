        "format": "lint-staged",
        "prepublishOnly": "npm run build",
        "prepare": "husky"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
