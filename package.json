        "oxlint": "^1.55.0",
        "turbo": "^2.8.17"
    },
    "lint-staged": {
        "*.{js,ts,tsx}": "oxlint --fix",
        "*": "oxfmt --no-error-on-unmatched-pattern"
    },
    "engines": {
        "node": ">=22"
    },
    "packageManager": "pnpm@10.32.1"
