{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", ".output/**"]
        },
        "palettecn#build": {
            "cache": false,
            "dependsOn": ["@palettecn/web#build"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "test": {
            "dependsOn": ["^build"],
            "cache": false,
            "outputs": []
        }
    }
}
